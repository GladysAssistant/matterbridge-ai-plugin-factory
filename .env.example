# GitHub Configuration
GITHUB_TOKEN=your_github_personal_access_token
GITHUB_REPO_OWNER=your_github_username
GITHUB_REPO_NAME=matterbridge-ai-plugin-factory

# Claude Code CLI Authentication
# Run "claude login" to authenticate with your Pro plan

# Factory Configuration
PLUGINS_OUTPUT_DIR=./plugins
ARTIFACTS_DIR=./artifacts
MAX_CONCURRENT_BUILDS=2

# Webhook Configuration (optional, for GitHub webhook integration)
WEBHOOK_SECRET=your_webhook_secret
WEBHOOK_PORT=3000

# Telegram notifications (optional)
# Create a bot via @BotFather and get your chat_id via @userinfobot
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
